{
    "name": "steven-gort/operaton-dmn-evaluator",
    "description": "WordPress plugin to integrate Gravity Forms with Operaton DMN decision tables for dynamic form evaluations.",
    "type": "wordpress-plugin",
    "license": "EUPL-1.2",
    "authors": [
        {
            "name": "Steven Gort",
            "email": "steven.gort@ictu.nl"
        }
    ],
    "require": {
        "php": ">=7.4",
        "yahnis-elsts/plugin-update-checker": "^5.0"
    },
    "autoload": {
        "psr-4": {
            "OperatonDMN\\": "includes/"
        }
    },
    "scripts": {
        "build": [
            "echo 'Building Operaton DMN Evaluator plugin...'"
        ]
    },
    "config": {
        "optimize-autoloader": true
    }
}